# ===================================================================
# SHIELDLY — Environment Variables
# ===================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!
# ===================================================================

# ── AI (Google Gemini — FREE) ───────────────────────────────────────
# Get free key at: https://aistudio.google.com
# Free tier: 15 requests/min, 1M tokens/day — more than enough at launch
GEMINI_API_KEY=

# ── Database & Auth (Supabase — FREE) ──────────────────────────────
# Get free project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Payments (Stripe — FREE until you earn money) ───────────────────
# Get keys at: https://stripe.com (use test keys for development)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs (create these in Stripe Dashboard) ────────────
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_...

# ── Email (Resend — FREE up to 3,000/month) ─────────────────────────
# Get free key at: https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@shieldly.io

# ── Security Scanning APIs (all FREE/optional) ─────────────────────
# Google Safe Browsing — free at console.cloud.google.com
GOOGLE_SAFE_BROWSING_KEY=
# HaveIBeenPwned — optional, skip for MVP
HIBP_API_KEY=

# ── App Config ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=
NODE_ENV=development

# ── Distributed Scan Worker (Docker Cluster - Stage 7) ──────────
# URL where your Docker worker is running
SCAN_WORKER_URL=http://localhost:4000
# Must match WORKER_SECRET in your scan-worker/docker-compose.yml
SCAN_WORKER_SECRET=zynth-super-secret-change-me
